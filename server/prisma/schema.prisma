generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String           @id @default(cuid())
  localId     String?          @unique
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id         String               @id @default(cuid())
  localId    String?              @unique
  username   String               @unique
  email      String?              @unique
  fullName   String
  passwordHash String?
  roleName   String?
  roleId     String?
  role       Role?                @relation(fields: [roleId], references: [id])
  status     String               @default("Active")
  active     Boolean              @default(true)
  lastLoginAt DateTime?
  failedLoginCount Int            @default(0)
  sessions   AuthSession[]
  auditLogs  AuditLog[]
  documents  DocumentAttachment[] @relation("DocumentUploadedBy")
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([email])
  @@index([status])
  @@map("users")
}

model AuthSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  refreshHash  String?
  expiresAt    DateTime
  revokedAt    DateTime?
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_sessions")
}

model Customer {
  id           String               @id @default(cuid())
  localId      String?              @unique
  customerName String
  companyName  String?
  phone        String?
  email        String?
  accountType  String?
  notes        String?
  archivedAt   DateTime?
  vehicles     Vehicle[]
  intakes      Intake[]
  repairOrders RepairOrder[]
  inspections   Inspection[]
  documents    DocumentAttachment[]
  serviceHistory ServiceHistoryRecord[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([customerName])
  @@map("customers")
}

model Vehicle {
  id               String               @id @default(cuid())
  localId          String?              @unique
  customerId       String?
  customer         Customer?            @relation(fields: [customerId], references: [id])
  plateNumber      String?
  conductionNumber String?
  make             String?
  model            String?
  year             String?
  color            String?
  mileage          Int?
  notes            String?
  archivedAt        DateTime?
  intakes          Intake[]
  inspections      Inspection[]
  repairOrders     RepairOrder[]
  serviceHistory   ServiceHistoryRecord[]
  documents        DocumentAttachment[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([plateNumber])
  @@index([customerId])
  @@map("vehicles")
}

model Intake {
  id                String    @id @default(cuid())
  localId           String?   @unique
  intakeNumber      String?   @unique
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  vehicleId         String?
  vehicle           Vehicle?  @relation(fields: [vehicleId], references: [id])
  customerName      String?
  plateNumber       String?
  conductionNumber  String?
  odometer          Int?
  requestedServices Json?
  concern           String?
  status            String?
  source            String?
  openedAt          DateTime?
  repairOrders      RepairOrder[]
  inspections       Inspection[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([intakeNumber])
  @@index([plateNumber])
  @@index([customerId])
  @@index([vehicleId])
  @@map("intakes")
}

model Inspection {
  id               String        @id @default(cuid())
  localId          String?       @unique
  inspectionNumber String?       @unique
  intakeId         String?
  intake           Intake?       @relation(fields: [intakeId], references: [id])
  repairOrderId    String?
  customerId       String?
  vehicleId        String?
  customer         Customer?     @relation(fields: [customerId], references: [id])
  vehicle          Vehicle?      @relation(fields: [vehicleId], references: [id])
  repairOrder      RepairOrder?  @relation(fields: [repairOrderId], references: [id])
  customerName     String?
  plateNumber      String?
  conductionNumber String?
  status           String?
  findings         Json?
  recommendations  Json?
  triggeredSections Json?
  tireDetails      Json?
  brakeDetails     Json?
  underHoodDetails Json?
  evidenceItems    Json?
  mediaMetadata    Json?
  technicianName   String?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([inspectionNumber])
  @@index([intakeId])
  @@index([repairOrderId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([plateNumber])
  @@map("inspections")
}

model RepairOrder {
  id                String               @id @default(cuid())
  localId           String?              @unique
  intakeId          String?
  intake            Intake?              @relation(fields: [intakeId], references: [id])
  repairOrderNumber String?              @unique
  customerId        String?
  customer          Customer?            @relation(fields: [customerId], references: [id])
  vehicleId         String?
  vehicle           Vehicle?             @relation(fields: [vehicleId], references: [id])
  customerName      String?
  plateNumber       String?
  status            String?
  advisorName       String?
  technicianName    String?
  odometer          Int?
  subtotal          Decimal?             @db.Decimal(12, 2)
  total             Decimal?             @db.Decimal(12, 2)
  openedAt          DateTime?
  completedAt       DateTime?
  workLines         WorkLine[]
  inspections       Inspection[]
  qcRecords         QcRecord[]
  releaseRecords    ReleaseRecord[]
  originalBackjobs  BackjobRecord[]      @relation("OriginalRepairOrderBackjobs")
  returnBackjobs    BackjobRecord[]      @relation("ReturnRepairOrderBackjobs")
  serviceHistory    ServiceHistoryRecord[]
  partsRequests     PartsRequest[]
  purchaseOrders    PurchaseOrder[]
  invoices          Invoice[]
  payments          Payment[]
  documents         DocumentAttachment[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([repairOrderNumber])
  @@index([intakeId])
  @@index([plateNumber])
  @@index([status])
  @@map("repair_orders")
}

model Invoice {
  id                String       @id @default(cuid())
  localId           String?      @unique
  invoiceNumber     String?      @unique
  repairOrderId     String?
  repairOrder       RepairOrder? @relation(fields: [repairOrderId], references: [id])
  customerName      String?
  plateNumber       String?
  status            String?
  subtotal          Decimal?     @db.Decimal(12, 2)
  total             Decimal      @db.Decimal(12, 2)
  balance           Decimal?     @db.Decimal(12, 2)
  issuedAt          DateTime?
  dueAt             DateTime?
  accountingStatus  String?
  payments          Payment[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([invoiceNumber])
  @@index([repairOrderId])
  @@index([status])
  @@map("invoices")
}

model WorkLine {
  id            String      @id @default(cuid())
  localId       String?     @unique
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  serviceKey    String?
  title         String
  category      String?
  status        String?
  technicianName String?
  approved      Boolean     @default(false)
  completed     Boolean     @default(false)
  quantity      Decimal?    @db.Decimal(12, 2)
  unitPrice     Decimal?    @db.Decimal(12, 2)
  unitCost      Decimal?    @db.Decimal(12, 2)
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([repairOrderId])
  @@index([serviceKey])
  @@map("work_lines")
}

model QcRecord {
  id                String       @id @default(cuid())
  localId           String?      @unique
  qcNumber          String?      @unique
  repairOrderId     String?
  repairOrder       RepairOrder? @relation(fields: [repairOrderId], references: [id])
  repairOrderNumber String?
  status            String?
  result            String?
  checklist         Json?
  passFailNotes     String?
  failedReasons     Json?
  reQcNotes         String?
  technicianMetadata Json?
  checkedBy         String?
  completedAt       DateTime?
  releaseRecords    ReleaseRecord[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([qcNumber])
  @@index([repairOrderId])
  @@index([status])
  @@map("qc_records")
}

model ReleaseRecord {
  id                 String       @id @default(cuid())
  localId            String?      @unique
  releaseNumber      String?      @unique
  repairOrderId      String?
  repairOrder        RepairOrder? @relation(fields: [repairOrderId], references: [id])
  qcRecordId         String?
  qcRecord           QcRecord?    @relation(fields: [qcRecordId], references: [id])
  repairOrderNumber  String?
  status             String?
  releaseChecklist   Json?
  handoverNotes      String?
  customerMessageSummary String?
  documentLinks      Json?
  releasedAt         DateTime?
  releasedBy         String?
  customerConfirmation Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([releaseNumber])
  @@index([repairOrderId])
  @@index([qcRecordId])
  @@index([status])
  @@map("release_records")
}

model BackjobRecord {
  id                    String       @id @default(cuid())
  localId               String?      @unique
  backjobNumber         String?      @unique
  originalRepairOrderId String?
  originalRepairOrder   RepairOrder? @relation("OriginalRepairOrderBackjobs", fields: [originalRepairOrderId], references: [id])
  returnRepairOrderId   String?
  returnRepairOrder     RepairOrder? @relation("ReturnRepairOrderBackjobs", fields: [returnRepairOrderId], references: [id])
  customerName          String?
  plateNumber           String?
  status                String?
  findings              Json?
  fixesPerformed        Json?
  rootCauseCategory     String?
  rootCause             Json?
  costType              String?
  technicianNotes       String?
  customerExplanation   String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([backjobNumber])
  @@index([originalRepairOrderId])
  @@index([returnRepairOrderId])
  @@index([status])
  @@map("backjob_records")
}

model ServiceHistoryRecord {
  id                String       @id @default(cuid())
  localId           String?      @unique
  customerId        String?
  customer          Customer?    @relation(fields: [customerId], references: [id])
  vehicleId         String?
  vehicle           Vehicle?     @relation(fields: [vehicleId], references: [id])
  repairOrderId     String?
  repairOrder       RepairOrder? @relation(fields: [repairOrderId], references: [id])
  customerName      String?
  plateNumber       String?
  serviceTitle      String
  category          String?
  completedAt       DateTime?
  odometer          Int?
  sourceModule      String?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([vehicleId])
  @@index([customerId])
  @@index([repairOrderId])
  @@index([completedAt])
  @@map("service_history_records")
}

model PartsRequest {
  id              String       @id @default(cuid())
  localId         String?      @unique
  requestNumber   String?      @unique
  repairOrderId   String?
  repairOrder     RepairOrder? @relation(fields: [repairOrderId], references: [id])
  supplierId      String?
  supplier        Supplier?    @relation(fields: [supplierId], references: [id])
  partName        String
  partNumber      String?
  category        String?
  quantity        Int?
  urgency         String?
  status          String?
  selectedBidId   String?
  plateNumber     String?
  requestedBy     String?
  bids            Json?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([requestNumber])
  @@index([repairOrderId])
  @@index([supplierId])
  @@map("parts_requests")
}

model InventoryItem {
  id             String   @id @default(cuid())
  localId        String?  @unique
  itemName       String
  sku            String?
  partNumber     String?
  category       String?
  brand          String?
  quantityOnHand Int      @default(0)
  reorderLevel   Int      @default(0)
  unitCost       Decimal? @db.Decimal(12, 2)
  sellingPrice   Decimal? @db.Decimal(12, 2)
  supplierName   String?
  active         Boolean  @default(true)
  movements      InventoryMovement[]
  movementLog    Json?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sku])
  @@index([partNumber])
  @@map("inventory_items")
}

model InventoryMovement {
  id              String         @id @default(cuid())
  localId         String?        @unique
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  movementType    String
  quantity        Int
  reason          String?
  sourceModule    String?
  linkedEntityId  String?
  note            String?
  createdBy       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([inventoryItemId])
  @@index([movementType])
  @@map("inventory_movements")
}

model PurchaseOrder {
  id              String       @id @default(cuid())
  localId         String?      @unique
  poNumber        String?      @unique
  supplierId      String?
  supplier        Supplier?    @relation(fields: [supplierId], references: [id])
  repairOrderId   String?
  repairOrder     RepairOrder? @relation(fields: [repairOrderId], references: [id])
  partsRequestId  String?
  supplierName    String?
  status          String?
  expectedDelivery DateTime?
  items           Json?
  receivingEvents Json?
  totalCost       Decimal?     @db.Decimal(12, 2)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([poNumber])
  @@index([supplierId])
  @@index([repairOrderId])
  @@map("purchase_orders")
}

model Supplier {
  id             String          @id @default(cuid())
  localId        String?         @unique
  supplierName   String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  brandsCarried  Json?
  categories     Json?
  active         Boolean         @default(true)
  notes          String?
  partsRequests  PartsRequest[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([supplierName])
  @@map("suppliers")
}

model Payment {
  id              String       @id @default(cuid())
  localId         String?      @unique
  paymentNumber   String?
  repairOrderId   String?
  repairOrder     RepairOrder? @relation(fields: [repairOrderId], references: [id])
  invoiceId       String?
  invoice         Invoice?     @relation(fields: [invoiceId], references: [id])
  customerName    String?
  plateNumber     String?
  method          String?
  status          String?
  amount          Decimal      @db.Decimal(12, 2)
  paidAt          DateTime?
  accountingStatus String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([repairOrderId])
  @@index([invoiceId])
  @@index([status])
  @@map("payments")
}

model Expense {
  id               String   @id @default(cuid())
  localId          String?  @unique
  expenseNumber    String?
  category         String?
  vendorName       String?
  description      String?
  amount           Decimal  @db.Decimal(12, 2)
  incurredAt       DateTime?
  status           String?
  accountingStatus String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([category])
  @@index([incurredAt])
  @@map("expenses")
}

model AuditLog {
  id         String   @id @default(cuid())
  localId    String?  @unique
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  userName   String?
  role       String?
  action     String
  module     String?
  entityType String?
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([action])
  @@index([module])
  @@index([entityId])
  @@map("audit_logs")
}

model DocumentAttachment {
  id                String       @id @default(cuid())
  localId           String?      @unique
  fileName          String
  fileType          String?
  fileSize          Int?
  storageKey        String?
  dataUrlHash       String?
  uploadedById      String?
  uploadedBy        User?        @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  sourceModule      String?
  linkedEntityId    String?
  linkedEntityLabel String?
  customerId        String?
  customer          Customer?    @relation(fields: [customerId], references: [id])
  vehicleId         String?
  vehicle           Vehicle?     @relation(fields: [vehicleId], references: [id])
  repairOrderId     String?
  repairOrder       RepairOrder? @relation(fields: [repairOrderId], references: [id])
  customerVisible   Boolean      @default(false)
  note              String?
  uploadedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([sourceModule])
  @@index([linkedEntityId])
  @@index([customerVisible])
  @@map("document_attachments")
}
